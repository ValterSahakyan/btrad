NODE_ENV=development
APP_PORT=3000

# Postgres credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production

DATABASE_URL=postgresql://postgres:change_me_in_production@localhost:5435/perpscout
REDIS_URL=redis://localhost:6379

# CORS — comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3001

BINANCE_API_KEY=
BINANCE_API_SECRET=

# Dashboard auth — set DASHBOARD_AUTH_ENABLED=true to require wallet login
# DASHBOARD_ALLOWED_WALLET is the only Ethereum address that can log in
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_ALLOWED_WALLET=0xd21760A4ad624d15ee37570B3C09Fd3Bff489309

# Telegram alerts — leave empty to disable
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
